# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/ai-job-tracker

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173

# Google Gemini AI (required for job analysis & resume parsing)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# RapidAPI — JSearch (required for job search feature)
# Subscribe at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=
